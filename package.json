{
  "name": "finbank-devsecops-lab",
  "version": "1.0.0",
  "description": "Laboratório DevSecOps - Aplicação bancária simulada com vulnerabilidades intencionais",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "jest tests/unit --runInBand",
    "test:integration": "cross-env NODE_ENV=test jest tests/integration --runInBand",
    "test:e2e": "cypress run",
    "test:smoke": "bash tests/smoke/run-smoke.sh",
    "test:upload": "bash tests/smoke/test-upload.sh",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:smoke && npm run test:e2e"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  }
}
